---
interface Props {
  class?: string;
  spotlight?: boolean;
  reveal?: boolean;
}

const { class: className = "", spotlight = false, reveal = false } = Astro.props;
---

<div
  data-spotlight={spotlight ? true : undefined}
  data-reveal={reveal ? true : undefined}
  class:list={[
    "group border-border bg-surface hover:border-accent/40 relative overflow-hidden rounded-2xl border p-8 transition-all duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:shadow-[0_16px_40px_-16px_rgba(6,182,196,0.35)]",
    className,
  ]}
>
  {
    spotlight && (
      <div
        class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(380px_circle_at_var(--spot-x,50%)_var(--spot-y,50%),rgba(6,182,196,0.16),transparent_65%)]"
        aria-hidden="true"
      />
    )
  }
  <div class="relative">
    <slot />
  </div>
</div>

{
  spotlight && (
    <script>
      const motionOK = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const pointerOK = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

      if (motionOK && pointerOK) {
        document.addEventListener("pointermove", (e) => {
          const card = (e.target as HTMLElement).closest<HTMLElement>("[data-spotlight]");
          if (!card) return;
          const rect = card.getBoundingClientRect();
          card.style.setProperty("--spot-x", `${e.clientX - rect.left}px`);
          card.style.setProperty("--spot-y", `${e.clientY - rect.top}px`);
        });
      }
    </script>
  )
}
