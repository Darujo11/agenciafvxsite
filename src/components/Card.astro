---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class:list={[
    "group border-border bg-surface hover:border-accent/40 rounded-2xl border p-8 transition-all duration-200 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:shadow-[0_16px_40px_-16px_rgba(6,182,196,0.35)]",
    className,
  ]}
>
  <slot />
</div>
