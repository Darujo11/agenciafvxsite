---
import Container from "@/components/Container.astro";
import Button from "@/components/Button.astro";
import Icon from "@/components/Icon.astro";
import GooeyText from "@/components/GooeyText";
import { buildWhatsappUrl } from "@/lib/constants";

const heroVerbos = ["venda mais", "cresça mais", "converta mais", "fature mais"];
---

<section id="top" class="relative isolate overflow-hidden pt-40 pb-28 lg:pt-52 lg:pb-36">
  <div class="absolute inset-0 -z-30 bg-bg" aria-hidden="true">
    <video
      id="hero-video"
      class="h-full w-full object-cover object-[72%_20%]"
      poster="/videos/hero-poster.jpg"
      muted
      loop
      playsinline
      autoplay
      preload="none"
      aria-hidden="true"
    >
    </video>
  </div>

  <div
    class="pointer-events-none absolute inset-0 -z-20 bg-bg/60"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-20 h-2/3 bg-gradient-to-t from-bg via-bg/70 to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 -z-20 h-[60rem] bg-[radial-gradient(ellipse_60%_50%_at_50%_-10%,rgba(6,182,196,0.28),transparent)] mix-blend-screen"
    aria-hidden="true"
  >
  </div>

  <Container class="flex flex-col items-center text-center">
    <h1
      class="animate-fade-up font-display text-hero text-text max-w-4xl leading-[1.05] tracking-tight text-balance"
    >
      Posicione sua empresa online e
      <GooeyText client:load texts={heroVerbos} textClassName="text-accent" />.
    </h1>

    <p
      class="animate-fade-up text-text-muted mt-8 max-w-2xl text-lg text-balance lg:text-xl"
      style="animation-delay: 0.1s;"
    >
      Presença que passa confiança, crescimento que dá pra medir e inteligência que economiza seu
      tempo.
    </p>

    <div
      class="animate-fade-up mt-10 flex flex-col items-center gap-4 sm:flex-row"
      style="animation-delay: 0.2s;"
    >
      <Button href={buildWhatsappUrl()} target="_blank">
        Fale com a gente
        <Icon name="whatsapp" class="h-4 w-4" />
      </Button>
      <Button href="/#servicos" variant="secondary"> Ver serviços </Button>
    </div>
  </Container>
</section>

<script>
  const section = document.getElementById("top");
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  if (section && video) {
    const motionOK = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const conn = (navigator as Navigator & { connection?: { saveData?: boolean; effectiveType?: string } })
      .connection;
    const connectionOK = !conn?.saveData && !["slow-2g", "2g"].includes(conn?.effectiveType ?? "");

    if (motionOK && connectionOK) {
      const source = document.createElement("source");
      source.src = "/videos/hero.mp4";
      source.type = "video/mp4";
      video.appendChild(source);
      video.load();
      video.play().catch(() => {});

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) video.play().catch(() => {});
          else video.pause();
        },
        { threshold: 0 }
      );
      observer.observe(section);

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) video.pause();
        else if (section.getBoundingClientRect().top < window.innerHeight) video.play().catch(() => {});
      });
    }
  }
</script>
