---
import Container from "@/components/Container.astro";
import Button from "@/components/Button.astro";
import Icon from "@/components/Icon.astro";
import { buildWhatsappUrl } from "@/lib/constants";
---

<section id="contato" class="relative overflow-hidden py-24 lg:py-32">
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-[40rem] bg-[radial-gradient(ellipse_60%_60%_at_50%_100%,rgba(6,182,196,0.18),transparent)]"
    aria-hidden="true"
  >
  </div>

  <Container>
    <div class="grid items-center gap-14 lg:grid-cols-2 lg:gap-20" data-reveal-group>
      <div class="text-center lg:text-left">
        <h2 class="font-display text-text text-4xl text-balance lg:text-5xl" data-reveal>
          Pronto para tirar seu projeto do papel?
        </h2>
        <p class="text-text-muted mx-auto mt-6 max-w-lg lg:mx-0" data-reveal>
          Manda uma mensagem no WhatsApp — a gente responde na hora e já começa o papo.
        </p>
        <Button
          href={buildWhatsappUrl()}
          target="_blank"
          class="mt-10 px-10 py-4 text-base"
          data-reveal
        >
          Chamar no WhatsApp
          <Icon name="whatsapp" class="h-5 w-5" />
        </Button>
      </div>

      <div class="relative" data-reveal>
        <div
          class="pointer-events-none absolute -inset-6 -z-10 rounded-[2.5rem] bg-[radial-gradient(circle_at_50%_40%,rgba(6,182,196,0.18),transparent_70%)]"
          aria-hidden="true"
        >
        </div>
        <div
          class="border-border bg-surface overflow-hidden rounded-3xl border shadow-[0_30px_60px_-20px_rgba(0,0,0,0.6)]"
        >
          <video
            id="cta-video"
            class="aspect-square w-full object-cover"
            poster="/videos/cta-final-poster.jpg"
            muted
            loop
            playsinline
            preload="none"
            aria-hidden="true"
          >
          </video>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const section = document.getElementById("contato");
  const video = document.getElementById("cta-video") as HTMLVideoElement | null;

  if (section && video) {
    const motionOK = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const conn = (
      navigator as Navigator & { connection?: { saveData?: boolean; effectiveType?: string } }
    ).connection;
    const connectionOK = !conn?.saveData && !["slow-2g", "2g"].includes(conn?.effectiveType ?? "");

    if (motionOK && connectionOK) {
      let loaded = false;
      const loadSource = () => {
        if (loaded) return;
        loaded = true;
        const source = document.createElement("source");
        source.src = "/videos/cta-final.mp4";
        source.type = "video/mp4";
        video.appendChild(source);
        video.load();
      };

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            loadSource();
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        },
        { threshold: 0, rootMargin: "200px 0px" }
      );
      observer.observe(section);

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          video.pause();
        } else if (section.getBoundingClientRect().top < window.innerHeight) {
          video.play().catch(() => {});
        }
      });
    }
  }
</script>
