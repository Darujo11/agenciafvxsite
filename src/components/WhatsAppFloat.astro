---
import Icon from "@/components/Icon.astro";
import { buildWhatsappUrl } from "@/lib/constants";
---

<a
  id="whatsapp-float"
  href={buildWhatsappUrl()}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar com a agenciaFVX no WhatsApp"
  class="bg-accent text-bg pointer-events-none fixed right-6 bottom-6 z-20 flex h-14 w-14 translate-y-4 items-center justify-center rounded-full opacity-0 shadow-[0_8px_24px_-8px_rgba(6,182,196,0.5)] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  <Icon name="whatsapp" class="h-6 w-6" />
</a>

<script>
  const float = document.getElementById("whatsapp-float");

  if (float) {
    const revelar = () => {
      const alemDoHero = window.scrollY > window.innerHeight * 0.8;
      float.classList.toggle("opacity-0", !alemDoHero);
      float.classList.toggle("translate-y-4", !alemDoHero);
      float.classList.toggle("pointer-events-none", !alemDoHero);
    };

    revelar();
    window.addEventListener("scroll", revelar, { passive: true });
  }
</script>
